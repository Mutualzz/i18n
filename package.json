{
    "devDependencies": {
        "bunchee": "^6.10.0",
        "i18next-cli": "^1.65.0"
    },
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        },
        "./types": {
            "import": "./dist/types.mjs",
            "require": "./dist/types.cjs",
            "types": "./dist/types.d.ts"
        }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "name": "@mutualzz/i18n",
    "private": true,
    "scripts": {
        "build": "pnpm typecheck && bunchee",
        "dev": "bunchee --watch",
        "extract": "i18next-cli extract",
        "extract:watch": "i18next-cli extract --watch",
        "i18n:lint": "i18next-cli lint",
        "i18n:status": "i18next-cli status",
        "i18n:sync": "i18next-cli sync",
        "i18n:types": "i18next-cli types",
        "refresh": "pnpm extract && pnpm i18n:sync && pnpm i18n:types && pnpm build",
        "typecheck": "tsc --noEmit"
    },

    "types": "./dist/index.d.ts"
}
